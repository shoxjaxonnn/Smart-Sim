# Copy to .env and fill. Without a key the backend runs in Mock mode (offline demo).
# --- Pick ONE provider. OpenRouter takes priority if both set. ---

# Option A: OpenRouter (works in regions where Google AI Studio is blocked).
# Get key: https://openrouter.ai/keys  (starts with sk-or-v1-)
OPENROUTER_API_KEY=
# Optional. Default: google/gemini-2.0-flash-exp:free
# Alternatives: meta-llama/llama-3.3-70b-instruct:free, mistralai/mistral-small-3.1-24b-instruct:free
OPENROUTER_MODEL=

# Option B: Direct Google AI Studio. Key format: AIzaSy... OR AQ.* (newer format).
# Both work with generateContent. Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional. Default: gemini-3.5-flash.
# 3.1 family: gemini-3.1-flash-lite (fast, tool-calling OK) | gemini-3.1-pro-preview (smart)
GEMINI_MODEL=

PORT=8080
SCENARIOS_DIR=scenarios
